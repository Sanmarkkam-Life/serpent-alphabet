# Author auto-sync (server-side only — never exposed to the browser).
# Copy to .env.local for local dev, and set the real values in Vercel
# (Project Settings -> Environment Variables) for production.

# Fine-grained Personal Access Token scoped to ONLY the serpent-alphabet
# repo, with "Contents: Read and write". Read server-side; never prefix
# NEXT_PUBLIC_ and never reference it from client code.
GITHUB_TOKEN=

# Any strong string the author picks. The /author UI asks for it once,
# stores it in sessionStorage, and sends it with each save; the server
# compares it before writing.
AUTHOR_PASSWORD=

# Repo coordinates. Defaults match this project; override only if needed.
GITHUB_REPO_OWNER=Sanmarkkam-Life
GITHUB_REPO_NAME=serpent-alphabet
GITHUB_BRANCH=main
